<section class="blog-section" id="blog">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <div class="hr-section">
          <big class="section-header">
              Blog
          </big>
        </div>
        <div class="row">
          <%= render partial: 'layouts/post', collection: @posts %>
        </div>
        <div>
          <a href="https://medium.brianemory.com/" target="_blank"><button class="btn btn-default">Read more posts on Medium</button></a>
        </div>
      </div>
    </div>
  </div>
</section>
