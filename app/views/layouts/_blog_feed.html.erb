<section class="blog-section" id="blog">
  <div class="container">
    <div class="row">
      <div class="col-lg-10 col-md-offset-1">
        <div class="hr-section">
          <big class="section-header">
              Blog
          </big>
        </div>
        <div class="row">
          <%= render partial: 'layouts/post', collection: @posts %>
        </div>
        <div>
          <%= link_to 'Read more posts on Medium', 'https://medium.brianemory.com', target: '_blank',
                                                    class: 'btn custom-btn' %>
        </div>
      </div>
    </div>
  </div>
</section>
