<div class="col-md-4 text-left">
  <h4 class="blog-title">
    <%= link_to post[:title], post[:link], target: '_blank' %>
    <small class="blue-text"><%= post[:date] %></small><br>
  </h4>
  <h5>
    <%= post[:heading] %>
  </h5>
  <p>
    <%= post[:content] %> <%= link_to 'Read more', post[:link], target: '_blank' %>
  </p>
  <br>
</div>
