<section class="projects-section" id="projects">
  <div class="container">
    <div class="row">
      <div class="col-lg-12">
        <div class="hr-section">
          <big class="section-header">
              Projects
          </big>
        </div>
          <!-- Project Template
          <div class="col-md-4">
            <h3>TITLE <a href="GITHUB" target="_blank"><div class="btn btn-xs btn-info gh-btn">GitHub</div></a></h3>
              <a href="LINK" target="_blank"><img class="img-responsive project-image" src="IMAGE"></a>
